{
  "name": "fitgirl-repacks-manager",
  "repository": "https://github.com/ANOOBALSA/FitGirl-Repacks-Manager.git",
  "productName": "FitGirl Repacks Manager",
  "displayName": "FitGirl Repacks Manager",
  "companyName": "Alsasoft",
  "version": "1.0.5",
  "description": "FitGirl Repacks Manager",
  "author": "Alsasoft",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "start": "next start",
    "lint": "next lint",
    "dev": "concurrently \"next dev\" \"tsc -p tsconfig.main.json && node scripts/inject-env.js && wait-on dist/index.js && wait-on tcp:3000 && electron .\"",
    "build": "next build && tsc -p tsconfig.main.json",
    "build:main": "next build && tsc -p tsconfig.main.json && node scripts/inject-env.js",
    "build:exe": "npm run build:main && electron-builder",
    "build:git": "npm run build && electron-builder",
    "release": "node scripts/release.js"
  },
  "build": {
    "appId": "com.fitgirl-repacks-manager.app",
    "publish": [
      {
        "provider": "github",
        "owner": "ANOOBALSA",
        "repo": "FitGirl-Repacks-Manager"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/app_icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "FitGirl Repacks Manager - v${version}.${ext}"
    },
    "files": [
      "dist/**/*",
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "**/node_modules/yt-dlp-exec/bin/*"
    ],
    "artifactName": "FitGirl Repacks Manager - v${version}.${ext}",
    "electronFuses": {
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true,
      "runAsNode": false,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false
    }
  },
  "dependencies": {
    "@mantine/carousel": "8.3.18",
    "@mantine/core": "8.3.18",
    "@mantine/dates": "8.3.18",
    "@mantine/hooks": "8.3.18",
    "@mantine/notifications": "8.3.18",
    "@tabler/icons-react": "^3.40.0",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "electron-log": "^5.4.3",
    "electron-serve": "^3.0.1",
    "eventsource": "^4.1.0",
    "fs-extra": "^11.2.0",
    "lenis": "^1.3.21",
    "framer-motion": "^12.38.0",
    "next": "^15.5.14",
    "next-electron-server": "^1.0.0",
    "node-unrar-js": "^2.0.2",
    "pocketbase": "^0.26.8",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-player": "^3.4.0",
    "embla-carousel-react": "^8.5.2",
    "dayjs": "^1.11.13",
    "yt-dlp-exec": "^1.0.2",
    "ytdl-core": "^4.11.5"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.3.3",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "9.35.0",
    "javascript-obfuscator": "^5.3.0",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.2",
    "wait-on": "^9.0.4"
  }
}
